.page { padding: 24rpx; }

.hero { text-align: center; padding: 30rpx 0 20rpx; }
.hero-title {
  font-size: 44rpx; font-weight: 700; color: #7a1f1f;
  font-family: "Songti SC", "STSong", serif;
}
.hero-meta { font-size: 26rpx; color: #8a7a5e; margin-top: 10rpx; }

.toolbar { display: flex; gap: 20rpx; margin: 20rpx 0; }
.tbtn {
  flex: 1; font-size: 28rpx; background: #fff; color: #7a1f1f;
  border: 1rpx solid #c9a36a; border-radius: 40rpx; padding: 12rpx 0;
}
.tbtn.primary { background: #7a1f1f; color: #fff; }
.tbtn.playing { background: #b8860b; color: #fff; border-color: #b8860b; }
.tip { font-size: 24rpx; color: #8a7a5e; margin: -8rpx 0 16rpx; line-height: 1.6; }

.card {
  background: #fff; border-radius: 16rpx; padding: 28rpx;
  margin-bottom: 24rpx; box-shadow: 0 2rpx 8rpx rgba(122, 31, 31, .06);
}

.poem-line {
  display: flex; align-items: center; justify-content: center;
  padding: 10rpx 0;
}
.line-text {
  font-size: 34rpx; line-height: 1.6; color: #2b2622;
  font-family: "Songti SC", "STSong", serif; text-align: center;
}

.section-title {
  font-size: 30rpx; font-weight: 700; color: #7a1f1f;
  display: block; margin-bottom: 14rpx;
}
.note-text { font-size: 28rpx; color: #4a4036; line-height: 1.7; }
.note-head {
  display: flex; align-items: center; justify-content: space-between;
  margin-bottom: 14rpx;
}
.note-head .section-title { margin-bottom: 0; }
.toggle { font-size: 26rpx; color: #b8860b; }
.note-text.muted { color: #9c8a68; }

.result-head {
  display: flex; align-items: center; justify-content: space-between;
  margin-bottom: 14rpx;
}
.offline-tag {
  font-size: 24rpx; color: #7a1f1f; background: #f1e3cd;
  padding: 4rpx 14rpx; border-radius: 8rpx;
}
.result-lines { margin: 10rpx 0; }
.rl-line {
  text-align: center; font-size: 32rpx; line-height: 1.7;
  font-family: "Songti SC", "STSong", serif;
}

.agreement-entry {
  display: flex; align-items: center; justify-content: center;
  margin: 10rpx 0 20rpx; font-size: 24rpx; color: #8a7a5e;
}
.agreement-link { color: #7a1f1f; text-decoration: underline; }
.agreement-desc { color: #9c8a68; margin-left: 8rpx; }

.nav-row { display: flex; gap: 20rpx; margin-top: 10rpx; }
.navbtn {
  flex: 1; font-size: 28rpx; background: #fff; color: #7a1f1f;
  border: 1rpx solid #c9a36a; border-radius: 40rpx;
}
