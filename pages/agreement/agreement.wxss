.page { padding: 30rpx; }
.title { font-size: 40rpx; font-weight: 700; color: #7a1f1f; text-align: center; }
.update { font-size: 24rpx; color: #9c8a68; text-align: center; margin: 10rpx 0 30rpx; }

.sec { margin-bottom: 28rpx; }
.sec-h { font-size: 30rpx; font-weight: 700; color: #2b2622; margin-bottom: 12rpx; }
.sec-p { font-size: 28rpx; color: #4a4036; line-height: 1.8; }
.strong { color: #7a1f1f; font-weight: 700; }

.actions { margin-top: 40rpx; display: flex; flex-direction: column; gap: 20rpx; }
.btn { font-size: 30rpx; border-radius: 40rpx; padding: 18rpx 0; }
.btn.agree { background: #7a1f1f; color: #fff; }
.btn.agreed { background: #f1e3cd; color: #7a1f1f; }
.btn.disagree { background: #fff; color: #b0a494; border: 1rpx solid #e3d9c7; }
