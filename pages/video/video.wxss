.page {
  padding: 40rpx 32rpx;
}
.v-head {
  text-align: center;
  margin-bottom: 24rpx;
}
.v-title {
  display: block;
  font-size: 40rpx;
  color: #7a1f1f;
  font-weight: 700;
}
.v-sub {
  display: block;
  font-size: 24rpx;
  color: #8a6d3b;
  margin-top: 10rpx;
}
.v-note {
  display: block;
  font-size: 26rpx;
  color: #4a4239;
  line-height: 1.8;
  text-align: justify;
  white-space: pre-line;
  background: #fbf6ec;
  border-radius: 14rpx;
  padding: 22rpx 24rpx;
  margin-bottom: 24rpx;
}
.ep-count {
  font-size: 24rpx;
  color: #b8860b;
  margin-bottom: 18rpx;
  text-align: center;
}
.ep-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}
.ep-card {
  display: flex;
  align-items: stretch;
  background: #fff;
  border: 1rpx solid #ecd9b0;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(122, 31, 31, 0.06);
}
.ep-badge {
  flex: 0 0 120rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #b8860b;
  color: #fff;
  font-size: 30rpx;
  font-weight: 700;
}
.ep-body {
  flex: 1;
  padding: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}
.ep-title {
  font-size: 28rpx;
  color: #3a322a;
  line-height: 1.6;
}
.ep-btn {
  align-self: flex-start;
  background: #7a1f1f;
  color: #fff;
  border-radius: 40rpx;
  font-size: 28rpx;
  line-height: 64rpx;
  height: 64rpx;
  padding: 0 36rpx;
}
.ep-btn::after {
  border: none;
}
