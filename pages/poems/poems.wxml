<view class="page" wx:if="{{author}}">
  <view class="list-head">
    <text class="lh-name serif-title">{{author.name}}</text>
    <text class="lh-count">{{searching ? filtered.length + ' 条结果' : '共 ' + poems.length + ' 首'}}</text>
  </view>

  <!-- 搜索框 -->
  <view class="search-bar">
    <view class="search-box">
      <text class="search-ico">🔍</text>
      <input class="search-input" placeholder="搜索诗名或内容" value="{{searchKey}}" bindinput="onSearchInput" confirm-type="search"/>
    </view>
    <view class="search-clear" wx:if="{{searching}}" bindtap="onClearSearch">取消</view>
  </view>

  <view class="poem-item card" wx:for="{{filtered}}" wx:key="id"
        data-id="{{item.id}}" bindtap="onTapPoem">
    <view class="pi-top">
      <text class="pi-title serif-title">{{item.title}}</text>
      <text class="tag">{{item.type}}</text>
    </view>
    <view class="pi-preview">{{item.firstLine}}…</view>
  </view>

  <view class="list-foot" wx:if="{{filtered.length === 0}}">未找到相关诗词</view>
  <view class="list-foot" wx:else>点击任意作品，查看原文、赏析与译文</view>
</view>
